{
  "name": "protoprism",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run spec:compile",
    "dev": "next dev",
    "prebuild": "npm run spec:compile",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "ci": "npm run lint && npm run type-check && npm run test && npm run build",
    "spec:compile": "npx tsx scripts/compile-presentation-spec.ts",
    "spec:watch": "npx tsx --watch scripts/compile-presentation-spec.ts",
    "mcp:start": "bash scripts/start-mcp-servers.sh start",
    "mcp:stop": "bash scripts/start-mcp-servers.sh stop",
    "mcp:status": "bash scripts/start-mcp-servers.sh status",
    "mcp:restart": "bash scripts/start-mcp-servers.sh restart"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.4.2",
    "@types/archiver": "^7.0.0",
    "@upstash/redis": "^1.37.0",
    "@vercel/blob": "^2.3.1",
    "archiver": "^7.0.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.34.3",
    "lightningcss-linux-arm64-gnu": "^1.32.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rss-parser": "^3.13.0",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "lint-staged": "^16.3.3",
    "prisma": "^7.4.2",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "vitest-mock-extended": "^3.1.0",
    "yaml": "^2.8.2"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "optionalDependencies": {
    "lightningcss": "^1.31.1"
  }
}
