// PRISM Intelligence Platform — Prisma Schema
// Aligned with swarm-protocol.md JSON schemas

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Run ─────────────────────────────────────────────────
// Mirrors swarm.json from swarm-protocol.md
// Lifecycle: INITIALIZE → SPAWN → EXECUTE → MONITOR → RESOLVE → SYNTHESIZE → DELIVER → OPTIMIZE
model Run {
  id              String   @id @default(cuid())
  query           String
  status          String   @default("INITIALIZE") // lifecycle phase
  tier            String   @default("STANDARD")   // MICRO | STANDARD | EXTENDED | MEGA | CAMPAIGN
  autonomyMode    String   @default("supervised")  // supervised | guided | autonomous
  complexityScore Int      @default(0)             // breadth + depth + interconnection (3-15)
  breadth         Int      @default(0)
  depth           Int      @default(0)
  interconnection Int      @default(0)
  estimatedTime   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  // Ownership (nullable for backward compatibility with pre-auth runs)
  createdById     String?
  teamId          String?
  visibility      String   @default("team")   // private | team | public

  // Relations
  agents               Agent[]
  findings             Finding[]
  synthesis            Synthesis[]
  dimensions           Dimension[]
  presentation         Presentation?
  memoryBusSnapshots   MemoryBusSnapshot[]
  irGraph              IrGraph?
  presentationQuality  PresentationQuality?
  toolCallLogs         ToolCallLog[]
  enrichedMetrics      EnrichedMetric[]
  agentDataRefs        AgentDataRef[]
  scenarios            Scenario[]
  createdBy            User?    @relation("UserRuns", fields: [createdById], references: [id], onDelete: SetNull)
  team                 Team?    @relation("TeamRuns", fields: [teamId], references: [id], onDelete: SetNull)

  @@index([createdById])
  @@index([teamId])
  @@index([status, createdAt(sort: Desc)])
  @@index([tier])
}

// ─── Dimension ───────────────────────────────────────────
// Analytical dimensions decomposed from the query
model Dimension {
  id          String @id @default(cuid())
  name        String
  description String
  runId       String
  run         Run    @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}

// ─── Agent ───────────────────────────────────────────────
// Mirrors agent roster from methodology-core.md §3
model Agent {
  id        String   @id @default(cuid())
  name      String
  archetype String                     // e.g. RESEARCHER-DATA, ANALYST-FINANCIAL
  mandate   String
  tools     String   @default("[]")    // JSON array of tool names
  dimension String                     // which dimension this agent covers
  color     String   @default("#59DDFD")
  status    String   @default("idle")  // idle | active | complete | failed
  progress  Int      @default(0)       // 0-100
  runId     String
  run       Run      @relation(fields: [runId], references: [id], onDelete: Cascade)

  findings  Finding[]

  @@unique([runId, name])
  @@index([runId])
}

// ─── Finding ─────────────────────────────────────────────
// Mirrors findings.json from swarm-protocol.md
model Finding {
  id           String @id @default(cuid())
  statement    String
  evidence     String
  confidence   String @default("MEDIUM") // HIGH | MEDIUM | LOW
  evidenceType String @default("direct") // direct | inferred | analogical | modeled
  source       String
  sourceUrl    String?
  sourceTier   String @default("SECONDARY") // PRIMARY | SECONDARY | TERTIARY
  implication  String
  action       String @default("keep")   // keep | dismiss | boost | flag
  tags         String @default("[]")     // JSON array
  metrics      String @default("[]")     // JSON array of metrics

  agentId String
  agent   Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  runId   String
  run     Run   @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([agentId])
  @@index([confidence])
}

// ─── Synthesis ───────────────────────────────────────────
// Mirrors merged.json layers from methodology-core.md §5-6
// 5 layers: foundation, convergence, tension, emergence, gap
model Synthesis {
  id          String @id @default(cuid())
  layerName   String              // foundation | convergence | tension | emergence | gap
  description String
  insights    String @default("[]") // JSON array of insight strings
  order       Int    @default(0)    // display order

  runId String
  run   Run    @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}

// ─── Presentation ────────────────────────────────────────
// Stores the generated HTML5 brief
model Presentation {
  id                 String   @id @default(cuid())
  title              String
  subtitle           String   @default("")
  htmlPath           String                    // path in public/decks/
  slideCount         Int      @default(0)
  currentVersionId   String?                   // Active draft version
  publishedVersionId String?                   // Last published version
  createdAt          DateTime @default(now())

  runId    String @unique
  run      Run    @relation(fields: [runId], references: [id], onDelete: Cascade)
  versions PresentationVersion[]
}

// ─── PresentationVersion ────────────────────────────────
// Versioned snapshot of the presentation's structured content
model PresentationVersion {
  id               String   @id @default(cuid())
  presentationId   String
  versionNumber    Int      @default(1)
  status           String   @default("draft")  // draft | review | approved | published
  label            String?                      // e.g. "AI-generated", "Post-edit v2"
  createdById      String?
  createdAt        DateTime @default(now())
  publishedAt      DateTime?

  presentation Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  slides       SlideVersion[]

  @@unique([presentationId, versionNumber])
  @@index([presentationId])
}

// ─── SlideVersion ───────────────────────────────────────
// Structured content for a single slide in a version
model SlideVersion {
  id               String   @id @default(cuid())
  versionId        String
  slideNumber      Int
  templateId       String?                     // Template used (e.g. "SF-01", "DV-03")
  backgroundVariant String  @default("gradient-dark")
  animationType    String   @default("stagger")
  content          Json                        // Structured SlideContent (headline, body, stats, charts, findings, sources)
  sourceAgentIds   String[] @default([])       // Agents that contributed to this slide
  sourceFindingIds String[] @default([])       // Finding IDs referenced
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  version     PresentationVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  annotations SlideAnnotation[]

  @@unique([versionId, slideNumber])
  @@index([versionId])
}

// ─── SlideAnnotation ──────────────────────────────────────
// Threaded comments/annotations on specific slide content
model SlideAnnotation {
  id          String   @id @default(cuid())
  slideId     String
  authorId    String?
  authorName  String   @default("Anonymous")
  content     String
  targetField String?                      // e.g. "headline", "body", "stats[0]", "findings[1]"
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  slide   SlideVersion      @relation(fields: [slideId], references: [id], onDelete: Cascade)
  replies AnnotationReply[]

  @@index([slideId])
}

// ─── AnnotationReply ──────────────────────────────────────
// Reply within an annotation thread
model AnnotationReply {
  id           String   @id @default(cuid())
  annotationId String
  authorId     String?
  authorName   String   @default("Anonymous")
  content      String
  createdAt    DateTime @default(now())

  annotation SlideAnnotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)

  @@index([annotationId])
}

// ─── MemoryBusSnapshot ──────────────────────────────────
// Captures MemoryBus state at key pipeline phases
model MemoryBusSnapshot {
  id                String   @id @default(cuid())
  phase             String                    // DEPLOY | SYNTHESIZE | COMPLETE
  snapshot          String   @default("{}")   // JSON blob of MemoryBusState
  entryCount        Int      @default(0)
  signalCount       Int      @default(0)
  conflictCount     Int      @default(0)
  openConflictCount Int      @default(0)
  createdAt         DateTime @default(now())
  runId             String
  run               Run      @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, phase])
}

// ─── IR Graph ───────────────────────────────────────────
// Assembled IR product artifact consumed by renderers
model IrGraph {
  id              String   @id @default(cuid())
  tier            String
  graph           String   @default("{}")  // JSON blob of IRGraph
  findingCount    Int      @default(0)
  emergenceCount  Int      @default(0)
  tensionCount    Int      @default(0)
  gapCount        Int      @default(0)
  qualityGrade    String?
  overallScore    Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  runId           String   @unique
  run             Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
}

// ─── Settings ────────────────────────────────────────────
// Platform configuration (singleton — one row with id="default")
model Settings {
  id                  String   @id @default("default")
  data                String   @default("{}")   // JSON blob of SettingsState
  onboardingDismissed Boolean  @default(false)
  hasCompletedTour    Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

// ─── ApiKey ──────────────────────────────────────────────
// Encrypted API keys for external providers
model ApiKey {
  id           String   @id @default(uuid())
  provider     String   @unique
  encryptedKey String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── PresentationQuality ──────────────────────────────────
// Quality telemetry from the agentic presentation pipeline
model PresentationQuality {
  id                  String   @id @default(cuid())
  overall             Float
  grade               String
  classNameValidity   Float
  structuralIntegrity Float
  chartAdoption       Float
  animationVariety    Float
  counterAdoption     Float
  emergenceHierarchy  Float
  sourceAttribution   Float
  slideCount          Int
  issueCount          Int
  reviewScore         Float?
  remediationRounds   Int      @default(0)
  // Template pipeline fields (new)
  templateCoverage     Float?
  renderSuccess        Float?
  dataBackedSlides     Float?
  valueAccuracy        Float?
  noHallucinations     Float?
  headlineSpecificity  Float?
  narrativeArcScore    Float?
  insightDensity       Float?
  templateVariety      Float?
  colorDistribution    Float?
  densityBalance       Float?
  transitionSmooth     Float?
  pipelineVersion      String  @default("v1")  // "v1" = legacy, "v2" = template
  planMs              Int?
  chartCompileMs      Int?
  generateMs          Int?
  assembleMs          Int?
  validateMs          Int?
  reviewMs            Int?
  remediateMs         Int?
  finalizeMs          Int?
  totalMs             Int?
  createdAt           DateTime @default(now())
  runId               String   @unique
  run                 Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
}

// ─── ToolCallLog ──────────────────────────────────────────
// Captures raw MCP tool call inputs/outputs during DEPLOY agents' execution
model ToolCallLog {
  id            String   @id @default(cuid())
  runId         String
  agentId       String
  mcpServer     String
  toolName      String
  toolParams    Json
  rawResponse   Json
  responseBytes Int
  latencyMs     Int
  capturedAt    DateTime @default(now())
  dataDomain    String?
  entityHints   String[]

  run             Run              @relation(fields: [runId], references: [id], onDelete: Cascade)
  enrichedMetrics EnrichedMetric[]

  @@index([runId])
  @@index([mcpServer])
  @@index([dataDomain])
  @@map("tool_call_log")
}

// ─── EnrichedMetric ───────────────────────────────────────
// Enriched/normalized metrics extracted from tool call responses
model EnrichedMetric {
  id           String   @id @default(cuid())
  runId        String
  sourceCallId String?
  dataShape    String
  metricName   String
  values       Json
  computed     Json
  pointCount   Int
  densityTier  String
  entityId     String?
  sourceLabel  String
  enrichedAt   DateTime @default(now())

  run        Run          @relation(fields: [runId], references: [id], onDelete: Cascade)
  sourceCall ToolCallLog? @relation(fields: [sourceCallId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([dataShape])
  @@index([entityId])
  @@map("enriched_metrics")
}

// ─── EntityRegistry ───────────────────────────────────────
// Canonical entity deduplication registry
model EntityRegistry {
  id            String   @id @default(cuid())
  canonicalName String
  entityType    String
  identifiers   Json
  aliases       String[]
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())

  @@unique([canonicalName, entityType])
  @@map("entity_registry")
}

// ─── Scenario ───────────────────────────────────────────────
// Fork of a completed run for "what-if" exploration
model Scenario {
  id          String    @id @default(cuid())
  name        String
  description String?
  runId       String                      // Base run this scenario forks from
  parentId    String?                     // Fork from another scenario (scenario trees)
  createdById String?                     // User who created this scenario
  status      String    @default("draft") // draft | computing | complete | failed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  run         Run        @relation(fields: [runId], references: [id], onDelete: Cascade)
  parent      Scenario?  @relation("ScenarioTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Scenario[] @relation("ScenarioTree")
  levers      ScenarioLever[]
  result      ScenarioResult?
  createdBy   User?      @relation("UserScenarios", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([parentId])
}

// ─── ScenarioLever ──────────────────────────────────────────
// Individual adjustment ("lever") within a scenario
model ScenarioLever {
  id          String  @id @default(cuid())
  scenarioId  String
  leverType   String  // tension_flip | gap_resolve | metric_adjust | finding_suppress | finding_amplify
  targetId    String  // ID of the IRTension, IRGap, EnrichedMetric, or IRFinding
  targetLabel String  // Human-readable label: "CMS Final Rule Direction"
  baseline    Json    // Original value/state
  adjusted    Json    // User's modified value/state
  impact      String? // After re-synthesis: high | medium | low

  scenario    Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
}

// ─── ScenarioResult ─────────────────────────────────────────
// Computed output of a scenario re-synthesis
model ScenarioResult {
  id                String   @id @default(cuid())
  scenarioId        String   @unique
  modifiedIrGraph   Json     // Full IRGraph with scenario mutations applied
  emergencesDelta   Json     // Which emergences changed, appeared, or disappeared
  tensionsDelta     Json     // Which tensions shifted
  sensitivityMap    Json     // Which levers had the biggest downstream impact
  confidenceShift   Float    // Overall confidence change vs baseline
  briefPath         String?  // Generated scenario brief HTML path
  memoPath          String?  // Generated scenario memo HTML path
  computedAt        DateTime @default(now())

  scenario          Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
}

// ─── AgentDataRef ─────────────────────────────────────────
// Links agent findings to their source data (tool calls)
model AgentDataRef {
  id           String   @id @default(cuid())
  runId        String
  agentId      String
  findingIndex Int
  toolCallId   String?
  relevance    String
  dataTypeHint String?
  annotation   String?
  createdAt    DateTime @default(now())

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@map("agent_data_refs")
}

// ═══════════════════════════════════════════════════════════
// AUTHENTICATION & TEAMS (NextAuth.js v5 / Auth.js)
// ═══════════════════════════════════════════════════════════

// ─── User ──────────────────────────────────────────────────
// NextAuth adapter model + Protoprism profile extensions
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  teamMembers   TeamMember[]
  runs          Run[]        @relation("UserRuns")
  scenarios     Scenario[]   @relation("UserScenarios")
}

// ─── Account ──────────────────────────────────────────────
// OAuth/credential accounts linked to a user
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─── Session ──────────────────────────────────────────────
// Active user sessions
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── VerificationToken ────────────────────────────────────
// Email verification / magic link tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Team ──────────────────────────────────────────────────
// Organization / team grouping for collaborative access
model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members TeamMember[]
  runs    Run[]        @relation("TeamRuns")
}

// ─── TeamMember ───────────────────────────────────────────
// Team membership with role-based access
model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      String   @default("analyst") // owner | admin | analyst | viewer
  joinedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
}

// ─── Phase 0A: Expansion Foundation ─────────────────────────

// RSS/Atom feed registry
model FeedSource {
  id                String    @id @default(cuid())
  url               String    @unique
  name              String
  feedType          String    @default("rss") // rss | atom | google_news
  category          String // regulatory, legislative, industry, research, ma-payer, innovation
  subcategory       String?
  pollIntervalHours Int       @default(4)
  enabled           Boolean   @default(true)
  lastPolledAt      DateTime?
  lastError         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  items FeedItem[]

  @@index([category])
  @@index([enabled])
}

// Stored feed articles with extracted metadata
model FeedItem {
  id          String   @id @default(cuid())
  sourceId    String
  title       String
  url         String
  summary     String?
  author      String?
  contentHash String // SHA-256 of title+url for dedup
  entities    String[] // Extracted entity names
  signals     String[] // Classified signal types
  tags        String[] // Additional tags
  publishedAt DateTime
  ingestedAt  DateTime @default(now())

  source FeedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, contentHash])
  @@index([sourceId])
  @@index([publishedAt])
  @@index([signals])
}

// Government dataset registry
model DatasetSource {
  id            String    @id @default(cuid())
  url           String    @unique
  name          String
  format        String    @default("csv") // csv | json | excel
  category      String // cms, fda, dea, general
  entityKeyField String
  compareFields String[]
  pollSchedule  String    @default("weekly") // daily | weekly | monthly
  enabled       Boolean   @default(true)
  lastPolledAt  DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  snapshots DatasetSnapshot[]

  @@index([category])
}

// Bulk dataset snapshots stored in blob storage
model DatasetSnapshot {
  id          String   @id @default(cuid())
  sourceId    String
  blobUrl     String // Vercel Blob URL
  recordCount Int
  sizeBytes   Int
  snapshotAt  DateTime @default(now())

  source DatasetSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  deltas DatasetDelta[]

  @@index([sourceId])
  @@index([snapshotAt])
}

// Snapshot diff records
model DatasetDelta {
  id         String   @id @default(cuid())
  snapshotId String
  changeType String // added | removed | modified
  entityKey  String
  fieldName  String?
  oldValue   String?
  newValue   String?
  detectedAt DateTime @default(now())

  snapshot DatasetSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([entityKey])
  @@index([changeType])
}

// Cross-source correlation signals
model Signal {
  id           String   @id @default(cuid())
  signalType   String // e.g., ma_convergence, regulatory_shift
  title        String
  description  String?
  sources      String[] // Source references
  confidence   Float // 0.0 to 1.0
  severity     String    @default("medium") // low | medium | high | critical
  entityRefs   String[] // Referenced entities
  patternId    String? // ID of the pattern that generated this signal
  metadata     Json?
  detectedAt   DateTime  @default(now())

  alerts Alert[]

  @@index([signalType])
  @@index([severity])
  @@index([detectedAt])
}

// SENTINEL notifications
model Alert {
  id             String    @id @default(cuid())
  signalId       String?
  alertType      String // signal_detected, source_error, threshold_breach
  title          String
  message        String
  severity       String    @default("medium") // low | medium | high | critical
  acknowledged   Boolean   @default(false)
  acknowledgedBy String?
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())

  signal Signal? @relation(fields: [signalId], references: [id], onDelete: SetNull)

  @@index([alertType])
  @@index([severity])
  @@index([acknowledged])
  @@index([signalId])
}
